<%- include("../partials/header") %>
<div class="container" style="margin-top: 100px; max-width: 400px;">
    <h1>Criar Conta</h1>
    <p>Cadastre-se para salvar seus contratos</p>
    
    <form action="/cadastro" method="POST">
        <input type="text" name="nome" placeholder="Seu nome completo" required>
        <input type="email" name="email" placeholder="Seu melhor e-mail" required>
        <input type="password" name="senha" placeholder="Crie uma senha segura" required>
        <button type="submit">Finalizar Cadastro</button>
    </form>
    <p style="margin-top: 20px;">Já tem conta? <a href="/login">Faça Login</a></p>
</div>
<script>
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('sucesso')) {
        Swal.fire({
            title: 'Sucesso!',
            text: 'Conta criada! Agora você já pode entrar.',
            icon: 'success',
            confirmButtonColor: '#2c3e50'
        });
    }
</script>
<%- include("../partials/footer") %>
